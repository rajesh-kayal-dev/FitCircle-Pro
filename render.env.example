# FitCircle Pro — Render / Deployment Environment Variables
# Copy this to render.env and fill in your real values.
# NEVER commit render.env! This file is for Render.com dashboard or VPS deployment.

# ── Database ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/fitcircle-diet
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Auth & Security ───────────────────────────────────────────
JWT_SECRET=your_strong_random_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
ADMIN_EMAIL=admin@fitcircle.com
ADMIN_PASSWORD=your_secure_admin_password_here

# ── AI / Search APIs ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# ── Cloudinary (Image Uploads) ────────────────────────────────
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# ── Email (Nodemailer / Gmail SMTP) ───────────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
