# FitCircle Pro — Server Environment Variables
# Copy this to .env and fill in your real values. NEVER commit .env!
# Real values must only exist in: GitHub Secrets + VPS .env

# ── Database ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/fitcircle
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth & Security ───────────────────────────────────────────
JWT_SECRET=your_strong_random_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── AI / Search APIs ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# ── Cloudinary (Image Uploads) ────────────────────────────────
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# ── Email (Nodemailer) ────────────────────────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Gateway ───────────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173

# ── Microservice URLs (all run in same container) ─────────────
AUTH_SERVICE=http://localhost:5001
USER_SERVICE=http://localhost:5002
USER_SERVICE_URL=http://localhost:5002
FEED_SERVICE=http://localhost:5003
STORE_SERVICE=http://localhost:5004
WORKOUT_SERVICE=http://localhost:5005
DIET_SERVICE=http://localhost:5006
CHAT_SERVICE=http://localhost:5007
